# ─────────────────────────────────────────────────────────────────────
# Raasta Kashmir — single .env for BOTH the Expo app and the server.
# Copy to `.env`. Everything is optional: with an empty .env the app runs
# in fully live DEMO MODE (simulated bus, mock auth, on-device AI).
# Fill a value and that subsystem switches to live automatically.
# ─────────────────────────────────────────────────────────────────────

# ── App → Backend (leave empty for self-contained demo mode) ─────────
# Your machine's LAN IP so a phone running Expo Go can reach the server,
# e.g. http://192.168.1.20:4000
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_SOCKET_URL=

# ── Google Maps (optional — Expo Go ships its own key for MapView) ───
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Firebase Authentication (leave empty for mock auth) ──────────────
# Mock logins: driver@raasta.com / parent@ / school@ / rto@raasta.com
# password: password123
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Server (server/ reads this same file) ────────────────────────────
PORT=4000
# Leave empty to use the in-memory store; set for persistent MongoDB.
MONGODB_URI=
# Leave empty to use deterministic AI fallback; set for real Gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
